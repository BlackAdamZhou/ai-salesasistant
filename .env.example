# OpenAI option
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# DeepSeek option. DeepSeek uses an OpenAI-compatible API.
DEEPSEEK_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash

# Optional limits. Leave unset to use provider/SDK defaults.
# AI_TIMEOUT_SECONDS=180
# AI_MAX_RETRIES=2
# AI_MAX_TOKENS=3000
